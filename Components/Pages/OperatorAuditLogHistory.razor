@page "/operator-audit-log-history"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject Microsoft.AspNetCore.Components.NavigationManager Nav
@inject OperatorAuditService OperatorAuditService
@inject EditRequestService EditRequestService
@inject CurrentUserService CurrentUserService

<PageTitle>Operator Self Inspection Log History</PageTitle>

<div class="sheet-container">
    <div class="sheet-title">Operator Self Inspection Log — Saved History</div>
    <button class="btn-back" @onclick="GoHome">← Back</button>

    <div class="row-controls">
        <input type="text" class="search-box" placeholder="Search by date, operator, shift, crew, line, formula, product type..."
               value="@searchTerm" @oninput="OnSearchInput" />
        <span class="row-count">@FilteredSheets.Count() of @allSheets.Count log@(allSheets.Count == 1 ? "" : "s")</span>
    </div>

    @if (isLoading)
    {
        <p class="history-empty">Loading...</p>
    }
    else if (!FilteredSheets.Any())
    {
        <p class="history-empty">No matching logs found.</p>
    }
    else
    {
        <div class="history-list">
            @foreach (var sheet in FilteredSheets)
            {
                var isExpanded = sheet.Id == expandedId;
                <div class="history-card">
                    <div class="history-card-header" @onclick="() => ToggleExpand(sheet.Id)">
                        <div class="history-card-main">
                            @if (!string.IsNullOrWhiteSpace(sheet.header.FlagComment))
                            {
                                <span class="history-field" title="@sheet.header.FlagComment">🚩</span>
                            }
                            <span class="history-date">@sheet.header.Date.ToString("yyyy-MM-dd")</span>
                            <span class="history-field"><strong>Operator:</strong> @sheet.header.OperatorName</span>
                            <span class="history-field"><strong>Shift:</strong> @sheet.header.Shift</span>
                            <span class="history-field"><strong>Crew:</strong> @sheet.header.Crew</span>
                            <span class="history-field"><strong>Line:</strong> @sheet.header.LineNumber</span>
                            <span class="history-field"><strong>Formula:</strong> @sheet.header.FormulaCode</span>
                            <span class="history-field">@sheet.rows.Count row@(sheet.rows.Count == 1 ? "" : "s")</span>
                            <span class="history-field"><strong>Created by:</strong> @(sheet.header.CreatedByName ?? "Unknown")</span>
                        </div>
                        <div class="history-card-actions">
                            @if (CanEdit(sheet.header))
                            {
                                <button class="btn-add btn-history-edit" @onclick="() => EditSheet(sheet.Id, sheet.header, sheet.rows)" @onclick:stopPropagation="true">Edit</button>
                                <button class="btn-danger btn-history-delete" @onclick="() => RequestDelete(sheet.Id)" @onclick:stopPropagation="true">Delete</button>
                            }
                            <span class="history-toggle">@(isExpanded ? "▲" : "▼")</span>
                        </div>
                    </div>
                    @if (isExpanded)
                    {
                        <OperatorAuditSheetView Header="sheet.header" Rows="sheet.rows" />
                    }
                </div>
            }
        </div>
    }
</div>

@if (pendingDeleteId is not null)
{
    <div class="copy-overlay">
        <div class="delete-dialog">
            <div class="delete-dialog-header">
                <h4>Confirm Deletion</h4>
            </div>
            <div class="delete-dialog-body">
                <p>Are you sure you want to delete this saved log?</p>
                <p class="delete-warning">This action cannot be undone.</p>
            </div>
            <div class="delete-dialog-footer">
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
                <button class="btn-danger" @onclick="ConfirmDelete">Yes, Delete</button>
            </div>
        </div>
    </div>
}

@code {
    private List<(int Id, OperatorSelfInspection.SheetHeader header, List<OperatorSelfInspection.SheetRow> rows)> allSheets = new();
    private string searchTerm = "";
    private bool isLoading = true;
    private int? expandedId;
    private int? pendingDeleteId;

    protected override async Task OnInitializedAsync()
    {
        await CurrentUserService.EnsureInitializedAsync();
        allSheets = await OperatorAuditService.GetAllSheetsAsync();
        isLoading = false;
    }

    private bool CanEdit(OperatorSelfInspection.SheetHeader header) =>
        CurrentUserService.IsMaster || (header.CreatedByUserId is not null && header.CreatedByUserId == CurrentUserService.UserId);

    private IEnumerable<(int Id, OperatorSelfInspection.SheetHeader header, List<OperatorSelfInspection.SheetRow> rows)> FilteredSheets =>
        string.IsNullOrWhiteSpace(searchTerm) ? allSheets : allSheets.Where(Matches);

    private bool Matches((int Id, OperatorSelfInspection.SheetHeader header, List<OperatorSelfInspection.SheetRow> rows) sheet)
    {
        var term = searchTerm.Trim();
        var header = sheet.header;

        if (Contains(header.Date.ToString("yyyy-MM-dd"), term) ||
            Contains(header.OperatorName, term) ||
            Contains(header.Shift, term) ||
            Contains(header.Crew, term) ||
            Contains(header.LineNumber, term) ||
            Contains(header.FormulaCode, term) ||
            Contains(header.ProductType1, term) ||
            Contains(header.ProductType2, term))
        {
            return true;
        }

        return sheet.rows.Any(r =>
            Contains(r.PalletBarcode, term) ||
            Contains(r.PalletNum, term) ||
            Contains(r.Grade, term));
    }

    private static bool Contains(string? field, string term) =>
        !string.IsNullOrEmpty(field) && field.Contains(term, StringComparison.OrdinalIgnoreCase);

    private void OnSearchInput(ChangeEventArgs e) => searchTerm = e.Value?.ToString() ?? "";

    private void ToggleExpand(int id)
    {
        expandedId = expandedId == id ? null : id;
    }

    private void RequestDelete(int id) => pendingDeleteId = id;

    private void CancelDelete() => pendingDeleteId = null;

    private async Task ConfirmDelete()
    {
        if (pendingDeleteId is not int id) return;

        await OperatorAuditService.DeleteSheetAsync(id);
        allSheets.RemoveAll(s => s.Id == id);
        pendingDeleteId = null;
    }

    private void EditSheet(int id, OperatorSelfInspection.SheetHeader header, List<OperatorSelfInspection.SheetRow> rows)
    {
        EditRequestService.SetPending("Operator", id, (header, rows));
        Nav.NavigateTo("/operator-self-inspection");
    }

    private void GoHome() => Nav.NavigateTo("/");
}
