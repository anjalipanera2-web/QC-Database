    private async Task ConfirmSave()
    {
        try
        {
            await PersistAsync();
            saveMessage = "Saved successfully!";
        }
        catch (Exception ex)
        {
            saveMessage = $"Error: {ex.Message}";
        }
        showSaveConfirmation = false;
    }

    <!--Autosave / unsaved-changes tracking-->
    private int? savedId;
    private string lastSavedSnapshot = "";
    private string autoSaveStatus = "";
    private bool showLeaveConfirmation = false;
    private System.Threading.Timer? autoSaveTimer;

    private string Snapshot() => System.Text.Json.JsonSerializer.Serialize(new { Sheet, DataRows });

    private async Task PersistAsync()
    {
        var setNames = string.Join(", ", MatchingRules.Select(r => r.SetName));
        foreach (var row in DataRows)
        {
            row.SpecSet = setNames;
        }

        if (savedId is int id)
        {
            await QCTestLogService.UpdateSheetAsync(id, Sheet, DataRows);
        }
        else
        {
            savedId = await QCTestLogService.SaveSheetAsync(Sheet, DataRows, CurrentUserService.UserId);
        }
        lastSavedSnapshot = Snapshot();
    }

    private async Task AutoSaveTick()
    {
        if (Snapshot() == lastSavedSnapshot) return;

        try
        {
            await PersistAsync();
            autoSaveStatus = $"Autosaved at {DateTime.Now:h:mm:ss tt}";
        }
        catch (Exception ex)
        {
            autoSaveStatus = $"Autosave failed: {ex.Message}";
        }
        StateHasChanged();
    }

    private void GoHome()
    {
        if (Snapshot() != lastSavedSnapshot)
        {
            showLeaveConfirmation = true;
        }
        else
        {
            Nav.NavigateTo("/");
        }
    }

    private async Task LeaveWithSaving()
    {
        await ConfirmSave();
        showLeaveConfirmation = false;
        Nav.NavigateTo("/");
    }

    private void LeaveWithoutSaving()
    {
        showLeaveConfirmation = false;
        Nav.NavigateTo("/");
    }

    private string autosaveMode = "Interval";

    protected override async Task OnInitializedAsync()
    {
        filmTypes = await SpecOptionsService.GetFilmTypesAsync();
        await CurrentUserService.EnsureInitializedAsync();

        var editRequest = EditRequestService.Consume("Test");
        if (editRequest is not null)
        {
            var (id, payload) = editRequest.Value;
            var (header, rows) = ((QCTestLogClassic.SheetHeader, List<QCTestLogClassic.SheetRow>))payload;
            Sheet = header;
            DataRows.Clear();
            DataRows.AddRange(rows);
            savedId = id;
            await RefreshRules();
        }
        else
        {
            DataRows.Add(new QCTestLogClassic.SheetRow());
            if (string.IsNullOrWhiteSpace(Sheet.QCTech))
            {
                Sheet.QCTech = CurrentUserService.UserName;
            }
        }

        lastSavedSnapshot = Snapshot();

        var settings = await AutosaveSettingsService.GetSettingsAsync();
        autosaveMode = settings.Mode;
        if (autosaveMode == "Interval")
        {
            autoSaveTimer = new System.Threading.Timer(
                _ => InvokeAsync(AutoSaveTick),
                null,
                TimeSpan.FromSeconds(settings.IntervalSeconds),
                TimeSpan.FromSeconds(settings.IntervalSeconds));
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && autosaveMode == "OnChange")
        {
            await AutoSaveTick();
        }
    }

    public void Dispose()
    {
        autoSaveTimer?.Dispose();
    }

    private QCTestLogClassic.SheetHeader Sheet = new();
    private List<QCTestLogClassic.SheetRow> DataRows = new();
    private List<(int Id, string Name)> filmTypes = new();
    private List<SpecRule> allRules = new();
}
