    private async Task RefreshRules()
    {
        if (string.IsNullOrWhiteSpace(Sheet.FilmType))
        {
            allRules = new();
            return;
        }
        allRules = await SpecRuleService.GetRulesForAsync(Sheet.FilmType);
    }

    private List<SpecRule> MatchingRules => allRules;

    private string GetSetsEmptyMessage()
    {
        if (string.IsNullOrWhiteSpace(Sheet.FilmType))
            return "Select a Film Type to see applicable specification sets.";
        return "No specification rules match this Film Type. Add one in Film Type & Formula Settings.";
    }

    private RenderFragment RenderMetricTag(MetricBracket? bracket) => @<text>
        @if (MatchingRules.Any())
        {
            <span class="set-tag @(bracket == null ? "no-match" : "")">
                <span class="dot"></span>@(bracket != null ? $"{SpecRuleService.FormatRange(bracket.GaugeMin, bracket.GaugeMax, "ga")} / {SpecRuleService.FormatRange(bracket.WidthMin, bracket.WidthMax, "in")}" : "No match")
            </span>
        }
    </text>;

    private bool? IsWithinManualSpec(string value)
    {
        if (string.IsNullOrWhiteSpace(Sheet.LSL1) && string.IsNullOrWhiteSpace(Sheet.USL1))
            return null;

        if (!decimal.TryParse(value, out var actual))
            return null;

        if (decimal.TryParse(Sheet.LSL1, out var lsl) && actual < lsl)
            return false;
        if (decimal.TryParse(Sheet.USL1, out var usl) && actual > usl)
            return false;

        return true;
    }

    private RenderFragment RenderManualSpecTag(string value) => @<text>
        @{ var status = IsWithinManualSpec(value); }
        @if (status is not null)
        {
            <span class="set-tag @(status == false ? "no-match" : "")">
                <span class="dot"></span>@(status == true ? "In Spec" : "Out of Spec")
            </span>
        }
    </text>;

    private void RecomputeAvgThickness(QCTestLogClassic.SheetRow row)
    {
        var values = new[] { row.ThicknessOuter1, row.ThicknessMiddle, row.ThicknessOuter2 }
            .Select(v => decimal.TryParse(v, out var d) ? (decimal?)d : null)
            .Where(v => v is not null)
            .Select(v => v!.Value)
            .ToList();

        row.AvgThickness = values.Any() ? values.Average().ToString("0.###") : "";
    }

    private List<(string Label, string Note)> GetSpecNotes(SpecRule r)
    {
        var candidates = new List<(string Label, string Note)>
        {
            (SpecRule.SpecLabels[0], r.Spec1),
            (SpecRule.SpecLabels[1], r.Spec2),
            (SpecRule.SpecLabels[2], r.Spec3),
            (SpecRule.SpecLabels[3], r.Spec4),
            (SpecRule.SpecLabels[4], r.Spec5),
            (SpecRule.SpecLabels[5], r.Spec6),
        };
        return candidates.Where(c => !string.IsNullOrWhiteSpace(c.Note)).ToList();
    }

    private async Task ExportToExcel()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Stretch Film Test Result Log");
        sb.AppendLine($"Date,{Esc(Sheet.Date.ToString("yyyy-MM-dd"))},QC Tech,{Esc(Sheet.QCTech)},Shift,{Esc(Sheet.Shift)},Crew,{Esc(Sheet.Crew)}");
        sb.AppendLine($"Line,{Esc(Sheet.Line)},Film Type,{Esc(Sheet.FilmType)},Formula,{Esc(Sheet.Formula)},Gauge,{Esc(Sheet.Gauge)}");
        sb.AppendLine($"Roll Weight LSL (Manual),{Esc(Sheet.LSL1)},Roll Weight Target (Manual),{Esc(Sheet.Target1)},Roll Weight USL (Manual),{Esc(Sheet.USL1)}");
        sb.AppendLine();
        sb.AppendLine("Specification Sets");
        foreach (var rule in MatchingRules)
        {
            sb.AppendLine($"Set,{Esc(rule.SetName)}");
            for (int m = 1; m <= SpecRule.MetricLabels.Length; m++)
            {
                var fc = rule.FieldConfigFor(m);
                var gaugeOnly = SpecRule.GaugeOnlyMetricIndexes.Contains(m);
                foreach (var b in rule.BracketsFor(m))
                {
                    var fields = new List<string> { "", Esc(SpecRule.MetricLabels[m - 1]), "Gauge", SpecRuleService.FormatRange(b.GaugeMin, b.GaugeMax) };
                    if (!gaugeOnly) { fields.Add("Width"); fields.Add(SpecRuleService.FormatRange(b.WidthMin, b.WidthMax)); }
                    if (fc.HasLSL) { fields.Add("LSL"); fields.Add(Esc(b.LSL)); }
                    if (fc.HasTarget) { fields.Add("Target"); fields.Add(Esc(b.Target)); }
                    if (fc.HasUSL) { fields.Add("USL"); fields.Add(Esc(b.USL)); }
                    sb.AppendLine(string.Join(",", fields));
                }
            }
        }
        sb.AppendLine();
        sb.AppendLine("Sample Time,Test Time,Roll Width,Test Roll Width,Position,Roll Weight,Ultimate Stretch %,Average Stretch %,Unwind,Out Cling,Out Cling Grade,In Cling,In Cling Grade,Barcode,Pallet #,Puncture,PW,Punct. Stdv.,Stretch Force,# of Punct.,Tail,Thickness Outer 1,Thickness Middle,Thickness Outer 2,Avg Thickness,Haze Lt. Trans.,Haze Stdv.,Gel Count,Remarks,Roll Status");
        foreach (var row in DataRows)
        {
            sb.AppendLine(string.Join(",",
                Esc(row.SampleTime.ToString("HH:mm")),
                Esc(row.TestTime.ToString("HH:mm")),
                Esc(row.RollWidth), Esc(row.TestRollWidth), Esc(row.Position), Esc(row.RollWeight),
                Esc(row.StretchP), Esc(row.AvgStretch), Esc(row.Unwind),
                Esc(row.AvgOutCling), Esc(row.OutClingGrade), Esc(row.AvgInCling), Esc(row.InClingGrade), Esc(row.Barcode), Esc(row.PalletNum), Esc(row.Puncture),
                Esc(row.PW), Esc(row.PunStdv), Esc(row.StretchForce),
                Esc(row.NumPunct), Esc(row.Tail), Esc(row.ThicknessOuter1), Esc(row.ThicknessMiddle), Esc(row.ThicknessOuter2), Esc(row.AvgThickness),
                Esc(row.LtTransm), Esc(row.HazeStdv), Esc(row.GelCount),
                Esc(row.Remarks), Esc(row.RollStatus)));
        }
        await JS.InvokeVoidAsync("downloadFile", "StretchFilmTestLog.csv", sb.ToString(), "text/csv;charset=utf-8;");
    }

