    private async Task ExportToExcel()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Stretch Film Reel Audit Log");
        sb.AppendLine($"Date,{Esc(Sheet.Date.ToString("yyyy-MM-dd"))},Time,{Esc(Sheet.Time == TimeOnly.MinValue ? "" : Sheet.Time.ToString("HH:mm"))},Line,{Esc(Sheet.LineNumber)},Shift,{Esc(Sheet.Shift)},Crew,{Esc(Sheet.Crew)}");
        sb.AppendLine($"Formula Code,{Esc(Sheet.FormulaCode)},Product Type,{Esc(Sheet.ProductType)},Width,{Esc(Sheet.Width)}");
        sb.AppendLine($"Footage (Charting),{Esc(Sheet.Charting)},Footage (Counter),{Esc(Sheet.Counter)}");
        sb.AppendLine($"Weight Spec LSL 1,{Esc(Sheet.LSL1)},Target 1,{Esc(Sheet.Target1)},USL 1,{Esc(Sheet.USL1)}");
        sb.AppendLine($"Weight Spec LSL 2,{Esc(Sheet.LSL2)},Target 2,{Esc(Sheet.Target2)},USL 2,{Esc(Sheet.USL2)}");
        sb.AppendLine($"Order Number,{Esc(Sheet.OrderNumber)},# of Pallets,{Esc(Sheet.NumPallets)},Barcode,{Esc(Sheet.Barcode)}");
        sb.AppendLine($"Notify Production,{Esc(Sheet.Notify)}");
        sb.AppendLine();
        sb.AppendLine("Charting Instructions");
        sb.AppendLine($"Web,{Esc(Sheet.Web)},Packing Code,{Esc(Sheet.PackingCode)},Unit,{Esc(Sheet.Unit)},Box #,{Esc(Sheet.BoxNum)},Die,{Esc(Sheet.Die)}");
        sb.AppendLine($"Layers/Pallet,{Esc(Sheet.LayersPallet)},Product,{Esc(Sheet.Product)},Box Label,{Esc(Sheet.BoxLabel)},QC Test Roll Pos,{Esc(Sheet.QCTestRollPos)}");
        sb.AppendLine($"RLS/CS/PLT,{Esc(Sheet.RLS)},Ex. Pallet Ticket,{Esc(Sheet.ExPalletTicket)},Pallets,{Esc(Sheet.PalletType)},PW,{Esc(Sheet.PW)}");
        sb.AppendLine($"Size,{Esc(Sheet.Size)},Condition,{Esc(Sheet.Condition)},Tail #,{Esc(Sheet.Tail)}");
        sb.AppendLine();
        sb.AppendLine("Pallet Data");
        sb.AppendLine("Pallet #,Pos.,Width,Core Prot.,Gross Weight,W#1,W#2,W#3,W#4");
        var pallets = new[]
        {
            new[] { Sheet.PalletNum1,  Sheet.Position1,  Sheet.Width1,  Sheet.CoreProtection1,  Sheet.GrossWeight1,  Sheet.Weight1_1,  Sheet.Weight1_2,  Sheet.Weight1_3,  Sheet.Weight1_4  },
            new[] { Sheet.PalletNum2,  Sheet.Position2,  Sheet.Width2,  Sheet.CoreProtection2,  Sheet.GrossWeight2,  Sheet.Weight2_1,  Sheet.Weight2_2,  Sheet.Weight2_3,  Sheet.Weight2_4  },
            new[] { Sheet.PalletNum3,  Sheet.Position3,  Sheet.Width3,  Sheet.CoreProtection3,  Sheet.GrossWeight3,  Sheet.Weight3_1,  Sheet.Weight3_2,  Sheet.Weight3_3,  Sheet.Weight3_4  },
            new[] { Sheet.PalletNum4,  Sheet.Position4,  Sheet.Width4,  Sheet.CoreProtection4,  Sheet.GrossWeight4,  Sheet.Weight4_1,  Sheet.Weight4_2,  Sheet.Weight4_3,  Sheet.Weight4_4  },
            new[] { Sheet.PalletNum5,  Sheet.Position5,  Sheet.Width5,  Sheet.CoreProtection5,  Sheet.GrossWeight5,  Sheet.Weight5_1,  Sheet.Weight5_2,  Sheet.Weight5_3,  Sheet.Weight5_4  },
            new[] { Sheet.PalletNum6,  Sheet.Position6,  Sheet.Width6,  Sheet.CoreProtection6,  Sheet.GrossWeight6,  Sheet.Weight6_1,  Sheet.Weight6_2,  Sheet.Weight6_3,  Sheet.Weight6_4  },
            new[] { Sheet.PalletNum7,  Sheet.Position7,  Sheet.Width7,  Sheet.CoreProtection7,  Sheet.GrossWeight7,  Sheet.Weight7_1,  Sheet.Weight7_2,  Sheet.Weight7_3,  Sheet.Weight7_4  },
            new[] { Sheet.PalletNum8,  Sheet.Position8,  Sheet.Width8,  Sheet.CoreProtection8,  Sheet.GrossWeight8,  Sheet.Weight8_1,  Sheet.Weight8_2,  Sheet.Weight8_3,  Sheet.Weight8_4  },
            new[] { Sheet.PalletNum9,  Sheet.Position9,  Sheet.Width9,  Sheet.CoreProtection9,  Sheet.GrossWeight9,  Sheet.Weight9_1,  Sheet.Weight9_2,  Sheet.Weight9_3,  Sheet.Weight9_4  },
            new[] { Sheet.PalletNum10, Sheet.Position10, Sheet.Width10, Sheet.CoreProtection10, Sheet.GrossWeight10, Sheet.Weight10_1, Sheet.Weight10_2, Sheet.Weight10_3, Sheet.Weight10_4 },
            new[] { Sheet.PalletNum11, Sheet.Position11, Sheet.Width11, Sheet.CoreProtection11, Sheet.GrossWeight11, Sheet.Weight11_1, Sheet.Weight11_2, Sheet.Weight11_3, Sheet.Weight11_4 },
        };
        foreach (var p in pallets)
        {
            if (p.Any(v => !string.IsNullOrWhiteSpace(v)))
                sb.AppendLine(string.Join(",", p.Select(v => Esc(v))));
        }
        await JS.InvokeVoidAsync("downloadFile", "StretchFilmReelAuditLog.csv", sb.ToString(), "text/csv;charset=utf-8;");
    }

    private async Task ExportToPdf()
    {
        await JS.InvokeVoidAsync("printPage");
    }

    private static string Esc(string s)
    {
        if (string.IsNullOrEmpty(s)) return "";
        if (s.Contains(',') || s.Contains('"') || s.Contains('\n'))
            return "\"" + s.Replace("\"", "\"\"") + "\"";
        return s;
    }
