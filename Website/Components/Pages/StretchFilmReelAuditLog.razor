@page "/stretch-film-reel-audit-log"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@implements IDisposable
@using Microsoft.AspNetCore.Components.Web
@inject Microsoft.AspNetCore.Components.NavigationManager Nav
@inject IJSRuntime JS
@inject QCAuditService QCAuditService
@inject EditRequestService EditRequestService
@inject AutosaveSettingsService AutosaveSettingsService
@inject CurrentUserService CurrentUserService

<PageTitle>Stretch Film Reel Audit Log</PageTitle>

<div class="sheet-container">
    <div class="sheet-title">Stretch Film Reel Audit Log</div>
    <button class="btn-back" @onclick="GoHome">← Back</button>
    <button class="btn-flag @(!string.IsNullOrWhiteSpace(Sheet.FlagComment) ? "flagged" : "")" @onclick="() => showFlagDialog = true">
        🚩 @(!string.IsNullOrWhiteSpace(Sheet.FlagComment) ? "Flagged" : "Flag")
    </button>
    <!--Header field tiles-->
    <div class="screen-only" style="padding: 10px 10px 2px;">
        <div class="field-group">
            <div class="field-group-label">Sheet Info</div>
            <table class="field-table">
                <tr>
                    <td class="band-1"><div class="f-tile"><div class="f-label">Date</div><input type="date" @bind="Sheet.Date" class="f-input" /></div></td>
                    <td class="band-1"><div class="f-tile"><div class="f-label">Time</div><TimeSelector @bind-Value="Sheet.Time"/></div></td>
                    <td class="band-1"><div class="f-tile"><div class="f-label">Line</div><input type="text" @bind="Sheet.LineNumber" placeholder="Line Number" class="f-input" /></div></td>
                    <td class="band-1">
                        <div class="f-tile">
                            <div class="f-label">Shift</div>
                            <select @bind="Sheet.Shift" class="f-input">
                                <option value="">-- Select --</option>
                                <option value="Day">Day</option>
                                <option value="Night">Night</option>
                            </select>
                        </div>
                    </td>
                    <td class="band-1">
                        <div class="f-tile">
                            <div class="f-label">Crew</div>
                            <select @bind="Sheet.Crew" class="f-input">
                                <option value="">-- Select --</option>
                                <option value="A">A</option>
                                <option value="B">B</option>
                                <option value="C">C</option>
                                <option value="D">D</option>
                            </select>
                        </div>
                    </td>
                    <td class="band-1"><div class="f-tile"><div class="f-label">Logged By</div><input type="text" @bind="Sheet.LoggedBy" class="f-input" /></div></td>
                </tr>
            </table>
        </div>

        <div class="field-group">
            <div class="field-group-label">Product</div>
            <table class="field-table">
                <tr>
                    <td class="band-2"><div class="f-tile"><div class="f-label">Formula Code</div><input type="text" @bind="Sheet.FormulaCode" class="f-input" /></div></td>
                    <td class="band-2"><div class="f-tile"><div class="f-label">Product Type</div><input type="text" @bind="Sheet.ProductType" class="f-input" /></div></td>
                    <td class="band-2"><div class="f-tile"><div class="f-label">Width</div><input type="text" @bind="Sheet.Width" placeholder="Width" class="f-input" /></div></td>
                    <td class="band-2"><div class="f-tile"><div class="f-label">Footage (Charting)</div><input type="text" @bind="Sheet.Charting" class="f-input" /></div></td>
                    <td class="band-2"><div class="f-tile"><div class="f-label">Footage (Counter)</div><input type="text" @bind="Sheet.Counter" class="f-input" /></div></td>
                </tr>
            </table>
        </div>

        <div class="field-group">
            <div class="field-group-label">Weight Spec 1</div>
