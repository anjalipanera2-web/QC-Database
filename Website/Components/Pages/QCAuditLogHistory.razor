@page "/qc-audit-log-history"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@rendermode InteractiveServer
@inject Microsoft.AspNetCore.Components.NavigationManager Nav
@inject QCAuditService QCAuditService
@inject EditRequestService EditRequestService
@inject CurrentUserService CurrentUserService

<PageTitle>Stretch Film Audit Log History</PageTitle>

<div class="sheet-container">
    <div class="sheet-title">Stretch Film Reel Audit Log — Saved History</div>
    <button class="btn-back" @onclick="GoHome">← Back</button>

    <div class="row-controls">
        <input type="text" class="search-box" placeholder="Search by date, line, shift, crew, formula, product type, order number, barcode..."
               value="@searchTerm" @oninput="OnSearchInput" />
        <span class="row-count">@FilteredSheets.Count() of @allSheets.Count log@(allSheets.Count == 1 ? "" : "s")</span>
    </div>

    @if (isLoading)
    {
        <p class="history-empty">Loading...</p>
    }
    else if (!FilteredSheets.Any())
    {
        <p class="history-empty">No matching logs found.</p>
    }
    else
    {
        <div class="history-list">
            @foreach (var entry in FilteredSheets)
            {
                var isExpanded = entry.Id == expandedId;
                <div class="history-card">
                    <div class="history-card-header" @onclick="() => ToggleExpand(entry.Id)">
                        <div class="history-card-main">
                            @if (!string.IsNullOrWhiteSpace(entry.sheet.FlagComment))
                            {
                                <span class="history-field" title="@entry.sheet.FlagComment">🚩</span>
                            }
                            <span class="history-date">@entry.sheet.Date.ToString("yyyy-MM-dd")</span>
                            <span class="history-field"><strong>Line:</strong> @entry.sheet.LineNumber</span>
                            <span class="history-field"><strong>Shift:</strong> @entry.sheet.Shift</span>
                            <span class="history-field"><strong>Crew:</strong> @entry.sheet.Crew</span>
                            <span class="history-field"><strong>Formula:</strong> @entry.sheet.FormulaCode</span>
                            <span class="history-field"><strong>Product:</strong> @entry.sheet.ProductType</span>
                            <span class="history-field"><strong>Order #:</strong> @entry.sheet.OrderNumber</span>
                            <span class="history-field"><strong>Created by:</strong> @(entry.sheet.CreatedByName ?? "Unknown")</span>
                        </div>
                        <div class="history-card-actions">
                            @if (CanEdit(entry.sheet))
                            {
                                <button class="btn-add btn-history-edit" @onclick="() => EditSheet(entry.Id, entry.sheet)" @onclick:stopPropagation="true">Edit</button>
                                <button class="btn-danger btn-history-delete" @onclick="() => RequestDelete(entry.Id)" @onclick:stopPropagation="true">Delete</button>
                            }
                            <span class="history-toggle">@(isExpanded ? "▲" : "▼")</span>
                        </div>
                    </div>
                    @if (isExpanded)
                    {
                        <QCAuditLogSheetView Sheet="entry.sheet" />
                    }
                </div>
            }
        </div>
    }
</div>

@if (pendingDeleteId is not null)
{
    <div class="copy-overlay">
        <div class="delete-dialog">
            <div class="delete-dialog-header">
                <h4>Confirm Deletion</h4>
            </div>
            <div class="delete-dialog-body">
                <p>Are you sure you want to delete this saved log?</p>
                <p class="delete-warning">This action cannot be undone.</p>
            </div>
            <div class="delete-dialog-footer">
                <button class="btn-secondary" @onclick="CancelDelete">Cancel</button>
                <button class="btn-danger" @onclick="ConfirmDelete">Yes, Delete</button>
            </div>
        </div>
    </div>
}

@code {
    private List<(int Id, StretchFilmReelAuditLog.SheetData sheet)> allSheets = new();
    private string searchTerm = "";
    private bool isLoading = true;
    private int? expandedId;
    private int? pendingDeleteId;

    protected override async Task OnInitializedAsync()
    {
        await CurrentUserService.EnsureInitializedAsync();
        allSheets = await QCAuditService.GetAllSheetsAsync();
        isLoading = false;
    }

    private bool CanEdit(StretchFilmReelAuditLog.SheetData sheet) =>
        CurrentUserService.IsMaster || (sheet.CreatedByUserId is not null && sheet.CreatedByUserId == CurrentUserService.UserId);

    private IEnumerable<(int Id, StretchFilmReelAuditLog.SheetData sheet)> FilteredSheets =>
        string.IsNullOrWhiteSpace(searchTerm) ? allSheets : allSheets.Where(Matches);

    private bool Matches((int Id, StretchFilmReelAuditLog.SheetData sheet) entry)
    {
        var term = searchTerm.Trim();
        var sheet = entry.sheet;

        return Contains(sheet.Date.ToString("yyyy-MM-dd"), term) ||
            Contains(sheet.LineNumber, term) ||
            Contains(sheet.Shift, term) ||
            Contains(sheet.Crew, term) ||
            Contains(sheet.FormulaCode, term) ||
            Contains(sheet.ProductType, term) ||
            Contains(sheet.OrderNumber, term) ||
            Contains(sheet.Barcode, term);
    }

    private static bool Contains(string? field, string term) =>
        !string.IsNullOrEmpty(field) && field.Contains(term, StringComparison.OrdinalIgnoreCase);

    private void OnSearchInput(ChangeEventArgs e) => searchTerm = e.Value?.ToString() ?? "";

    private void ToggleExpand(int id)
    {
        expandedId = expandedId == id ? null : id;
    }

    private void RequestDelete(int id) => pendingDeleteId = id;

    private void CancelDelete() => pendingDeleteId = null;

    private async Task ConfirmDelete()
    {
        if (pendingDeleteId is not int id) return;

        await QCAuditService.DeleteSheetAsync(id);
        allSheets.RemoveAll(s => s.Id == id);
        pendingDeleteId = null;
    }

    private void EditSheet(int id, StretchFilmReelAuditLog.SheetData sheet)
    {
        EditRequestService.SetPending("Audit", id, sheet);
        Nav.NavigateTo("/stretch-film-reel-audit-log");
    }

    private void GoHome() => Nav.NavigateTo("/");
}
